# ── Outputs generados (no se versiona el contenido de cliente) ──
output/

# ── Contexto real de proyectos (el PM pone el suyo, nunca se versiona) ──
# Bloquea cualquier .md que no sea README o .template
docs/contexto/*.md
!docs/contexto/README.md
!docs/contexto/*.template.md

# ── HUs reales de proyectos ──
docs/HUs/Sprint-*/
!docs/HUs/README.md

# ── Sistema operativo ──
.DS_Store
Thumbs.db

# ── IDEs ──
.vscode/
.idea/
*.swp

# ── Node ──
node_modules/
